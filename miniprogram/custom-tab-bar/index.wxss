/* ======== 悬浮毛玻璃导航栏 ======== */
.float-bar {
  position: fixed;
  bottom: 36rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  min-width: 520rpx;
  border-radius: 999rpx;
  background: rgba(18, 18, 24, 0.72);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 24rpx 60rpx rgba(0, 0, 0, 0.45),
    0 0 0 1rpx rgba(255, 255, 255, 0.04) inset;
  z-index: 9999;
}

.bar-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 96rpx;
  border-radius: 28rpx;
  transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-item-active {
  background: rgba(46, 107, 255, 0.15);
}

.bar-icon {
  font-size: 38rpx;
  line-height: 1;
  margin-bottom: 4rpx;
  transition: transform 0.25s ease;
}

.bar-item-active .bar-icon {
  transform: scale(1.12);
}

.bar-label {
  font-size: 20rpx;
  color: #6B7280;
  font-weight: 500;
  transition: color 0.25s ease;
}

.bar-item-active .bar-label {
  color: #FFFFFF;
  font-weight: 600;
}

/* 选中指示小圆点 */
.bar-dot {
  position: absolute;
  bottom: 6rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2E6BFF;
  box-shadow: 0 0 12rpx rgba(46, 107, 255, 0.6);
}
