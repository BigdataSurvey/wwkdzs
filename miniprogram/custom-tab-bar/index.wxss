/* ======== 悬浮毛玻璃导航栏 (亮色高定版) ======== */
.float-bar {
  position: fixed;
  bottom: 36rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  min-width: 520rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.08);
  z-index: 9999;
}

.bar-item {
position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 84rpx; /* 稍微调扁一点，更精致 */
  border-radius: 20rpx; /* 改为小圆角矩形色块 */
  transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-item-active {
  background: #2E6BFF;
  box-shadow: 0 8rpx 20rpx rgba(46, 107, 255, 0.2);
}

.bar-icon {
  font-size: 38rpx;
  line-height: 1;
  margin-bottom: 4rpx;
  transition: transform 0.25s ease;
}

.bar-item-active .bar-icon {
  transform: translateY(2rpx); /* 去掉放大，改为微下沉 */+
}

.bar-label {
  font-size: 20rpx;
  color: #9CA3AF;
  font-weight: 500;
  transition: color 0.25s ease;
}

.bar-item-active .bar-label {
  color: #FFFFFF;
  font-weight: 600;
}

.bar-dot { display: none; }