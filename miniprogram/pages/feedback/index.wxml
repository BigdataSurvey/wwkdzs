<view class="page">
  <view class="section card panel">
    <view class="section-title">反馈类型</view>
    <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="picker-line">{{categories[categoryIndex]}}</view>
    </picker>
  </view>

  <view class="section card panel">
    <view class="section-title">详细描述</view>
    <textarea class="feedback-textarea" placeholder="例如：首页行业空状态文案还可以更强，答题页结果按钮需要更有仪式感..." maxlength="300" bindinput="onInput"></textarea>
  </view>

  <view class="section">
    <view class="primary-btn" bindtap="submit">提交反馈</view>
  </view>
</view>
