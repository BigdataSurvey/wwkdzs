/* ======== 全局背景层 ======== */
.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.step-page { position: relative; z-index: 1; overflow: hidden; padding: 0; min-height: 100vh; color: #333; }

/* ======== 1. 顶部进度条 ======== */
.progress-header { padding: 40rpx 40rpx 20rpx; text-align: center; }
.progress-title { font-size: 38rpx; font-weight: 700; color: #111; margin-bottom: 30rpx; }
.progress-bar-container { width: 60%; height: 8rpx; background: #E5E7EB; border-radius: 999rpx; margin: 0 auto 16rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; background: #2E6BFF; border-radius: 999rpx; transition: width 0.4s ease; }
.progress-labels { display: flex; justify-content: space-around; width: 70%; margin: 0 auto; font-size: 22rpx; color: #9CA3AF; font-weight: 500; }
.label-active { color: #2E6BFF; font-weight: 700; }

/* 容器与面板 */
.step-container { display: flex; width: 200%; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
.step-panel { width: 50%; padding: 0 32rpx 40rpx; box-sizing: border-box; }
.step-subtitle-top { font-size: 26rpx; color: #666; text-align: center; margin-bottom: 40rpx; }

/* ======== 2. 行业网格 ======== */
.industry-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.industry-card {
  position: relative; width: calc(50% - 10rpx); min-height: 200rpx; padding: 28rpx;
  border-radius: 24rpx; border: 1rpx solid rgba(0,0,0,0.04); background: #FFF;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); box-sizing: border-box; transition: all 0.2s ease;
}
.industry-active { border-color: rgba(46,107,255,0.4); background: #F5F9FF; box-shadow: 0 12rpx 32rpx rgba(46,107,255,0.1); }
.industry-icon { width: 72rpx; height: 72rpx; border-radius: 20rpx; background: rgba(46,107,255,0.06); display: flex; align-items: center; justify-content: center; font-size: 32rpx; margin-bottom: 20rpx; }
.industry-name { font-size: 32rpx; font-weight: 700; color: #111; margin-bottom: 8rpx; }
.industry-tag { font-size: 22rpx; color: #888; line-height: 1.4; }
.industry-check { position: absolute; top: 20rpx; right: 20rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background: #2E6BFF; color: #FFF; font-size: 22rpx; display: flex; align-items: center; justify-content: center; }

/* ======== 3. 面包屑导航 ======== */
.breadcrumb {
  display: inline-flex; align-items: center; background: #F0F5FF; padding: 12rpx 28rpx;
  border-radius: 999rpx; margin-bottom: 30rpx;
}
.bc-prev { font-size: 26rpx; color: #1A4BFF; font-weight: 600; }
.bc-divider { font-size: 24rpx; color: #A0AAB5; margin: 0 16rpx; }
.bc-curr { font-size: 26rpx; color: #666; font-weight: 500; }

/* ======== 4. 场景化阶段卡片 ======== */
.stage-list { display: flex; flex-direction: column; gap: 24rpx; }
.stage-card-pro {
  position: relative; background: #FFF; border: 1rpx solid #E5E7EB; border-radius: 24rpx;
  padding: 32rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.02); transition: all 0.25s ease; overflow: hidden;
}
.stage-active-pro { border-color: #2E6BFF; background: #F5F9FF; box-shadow: 0 16rpx 40rpx rgba(46,107,255,0.1); transform: translateY(-4rpx); }

/* 左侧指示条 */
.active-indicator { position: absolute; left: 0; top: 0; bottom: 0; width: 8rpx; background: #2E6BFF; }

.sc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.sc-title { font-size: 34rpx; font-weight: 700; color: #111; display: flex; align-items: center; }
.sc-icon { font-size: 40rpx; margin-right: 16rpx; }

/* 仿单选框 */
.sc-radio { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #D1D5DB; display: flex; align-items: center; justify-content: center; }
.stage-active-pro .sc-radio { border-color: #2E6BFF; }
.radio-inner { width: 24rpx; height: 24rpx; border-radius: 50%; background: #2E6BFF; }

.sc-divider { height: 1rpx; background: #F3F4F6; margin-bottom: 20rpx; }
.stage-active-pro .sc-divider { background: rgba(46,107,255,0.1); }
.sc-desc { font-size: 28rpx; color: #444; line-height: 1.5; margin-bottom: 16rpx; }

/* 场景标签 */
.sc-scenario { font-size: 24rpx; color: #1A4BFF; background: rgba(46,107,255,0.06); display: inline-block; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: 500; }

/* ======== 5. 底部按钮与安全提示 ======== */
.step-action { margin-top: 50rpx; text-align: center; }
.safe-tips { font-size: 24rpx; color: #9CA3AF; margin-bottom: 20rpx; display: flex; align-items: center; justify-content: center; }
.safe-tips::before, .safe-tips::after { content: ''; width: 40rpx; height: 1rpx; background: #E5E7EB; margin: 0 16rpx; }
.primary-btn {
  background: #2E6BFF; color: #FFF; padding: 28rpx 0; border-radius: 20rpx;
  font-size: 32rpx; font-weight: 700; box-shadow: 0 12rpx 32rpx rgba(46,107,255,0.25); transition: all 0.2s ease;
}
.btn-hover { transform: scale(0.98); opacity: 0.9; }
.tap-scale { transform: scale(0.96); }
.tap-scale-card { transform: scale(0.98); }