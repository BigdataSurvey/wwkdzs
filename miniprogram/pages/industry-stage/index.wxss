.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.step-page { position: relative; z-index: 1; overflow: hidden; padding: 0; min-height: 100vh; color: #333; }

.progress-header { padding: 40rpx 40rpx 20rpx; text-align: center; }
.progress-title { font-size: 38rpx; font-weight: 700; color: #111; margin-bottom: 30rpx; }
.progress-bar-container { width: 60%; height: 8rpx; background: #E5E7EB; border-radius: 999rpx; margin: 0 auto 16rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; background: #2E6BFF; border-radius: 999rpx; transition: width 0.4s ease; }
.progress-labels { display: flex; justify-content: space-around; width: 70%; margin: 0 auto; font-size: 22rpx; color: #9CA3AF; font-weight: 500; }
.label-active { color: #2E6BFF; font-weight: 700; }

.step-container { display: flex; width: 200%; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
.step-panel { width: 50%; padding: 0 32rpx 40rpx; box-sizing: border-box; }
.step-subtitle-strong { font-size: 26rpx; color: #555555; text-align: center; margin-bottom: 40rpx; font-weight: 500; } /* 加深副标题 */

.industry-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.industry-card {
  position: relative; width: calc(50% - 10rpx); min-height: 200rpx; padding: 28rpx;
  border-radius: 24rpx; border: 2rpx solid transparent; background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); box-sizing: border-box; transition: all 0.2s ease;
}
/* 优化 5：网格极其明显的浅蓝填充 + 蓝边框 */
.industry-active { border-color: #2E6BFF; background: #F0F7FF; box-shadow: 0 12rpx 32rpx rgba(46,107,255,0.15); }
.industry-icon { width: 72rpx; height: 72rpx; border-radius: 20rpx; background: #F3F4F6; display: flex; align-items: center; justify-content: center; font-size: 32rpx; margin-bottom: 20rpx; transition: background 0.2s; }
.industry-active .industry-icon { background: rgba(46,107,255,0.15); } /* 图标底色变深 */
.industry-name { font-size: 32rpx; font-weight: 700; color: #111; margin-bottom: 8rpx; }
.industry-tag { font-size: 22rpx; color: #888; line-height: 1.4; }
.industry-check { position: absolute; top: 20rpx; right: 20rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background: #2E6BFF; color: #FFF; font-size: 22rpx; display: flex; align-items: center; justify-content: center; }

/* 明确的返回面包屑 */
.breadcrumb-pro {
  display: inline-flex; align-items: center; background: rgba(0,0,0,0.04); padding: 14rpx 32rpx;
  border-radius: 999rpx; margin-bottom: 30rpx; border: 1rpx solid rgba(0,0,0,0.05);
}
.bc-arrow { font-size: 36rpx; color: #666; margin-right: 12rpx; line-height: 1; margin-top: -4rpx; }
.bc-text { font-size: 26rpx; color: #444; font-weight: 600; }

.stage-list { display: flex; flex-direction: column; gap: 24rpx; }
.stage-card-pro {
  position: relative; background: #FFF; border: 2rpx solid transparent; border-radius: 24rpx;
  padding: 32rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04); transition: all 0.25s ease;
}
/* 阶段卡片强选中态 */
.stage-active-pro { border-color: #2E6BFF; background: #F5F9FF; box-shadow: 0 16rpx 40rpx rgba(46,107,255,0.1); }

.sc-header { display: flex; align-items: center; margin-bottom: 20rpx; }
.sc-title { font-size: 34rpx; font-weight: 700; color: #111; display: flex; align-items: center; }
/* 左侧复选框 */
.sc-checkbox { width: 44rpx; height: 44rpx; border-radius: 50%; background: #2E6BFF; color: #FFF; display: flex; align-items: center; justify-content: center; font-size: 28rpx; margin-right: 16rpx; font-weight: bold; }
.sc-checkbox-empty { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #D1D5DB; margin-right: 16rpx; }
.sc-icon { font-size: 40rpx; margin-right: 12rpx; }

.sc-divider { height: 1rpx; background: #F3F4F6; margin-bottom: 20rpx; }
.stage-active-pro .sc-divider { background: rgba(46,107,255,0.1); }
.sc-desc { font-size: 28rpx; color: #444; line-height: 1.5; margin-bottom: 16rpx; font-weight: 500; }

/* 优化 6：灰色场景标签，绝对不和蓝色抢戏 */
.sc-scenario-grey { font-size: 24rpx; color: #666666; background: #F3F4F6; display: inline-block; padding: 8rpx 20rpx; border-radius: 12rpx; font-weight: 500; border: 1rpx solid #E5E7EB; }

.step-action { margin-top: 50rpx; text-align: center; }
.safe-tips { font-size: 24rpx; color: #9CA3AF; margin-bottom: 20rpx; display: flex; align-items: center; justify-content: center; }
.safe-tips::before, .safe-tips::after { content: ''; width: 40rpx; height: 1rpx; background: #E5E7EB; margin: 0 16rpx; }
.primary-btn { background: #2E6BFF; color: #FFF; padding: 28rpx 0; border-radius: 20rpx; font-size: 32rpx; font-weight: 700; box-shadow: 0 12rpx 32rpx rgba(46,107,255,0.25); transition: all 0.2s ease; }
.btn-hover { transform: scale(0.98); opacity: 0.9; }
.tap-scale { transform: scale(0.96); }
.tap-scale-card { transform: scale(0.98); }