/* ======== 全局背景层 ======== */
.custom-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  opacity: 1;
}

/* 两步交互页面 */
.step-page {
  position: relative;
  z-index: 1;
  overflow: hidden;
  padding: 0;
  min-height: 100vh;
  color: #333333; /* 基础文字颜色 */
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 30rpx;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E5E7EB; /* 浅色背景 */
  color: #6B7280;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.step-dot-active {
  background: #2E6BFF;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(46, 107, 255, 0.25);
}

.step-line {
  width: 120rpx;
  height: 4rpx;
  background: #E5E7EB;
  margin: 0 20rpx;
  transition: all 0.3s ease;
}

.step-line-active {
  background: #2E6BFF;
}

/* 步骤容器 - 横向滑动 */
.step-container {
  display: flex;
  width: 200%;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.step-panel {
  width: 50%;
  padding: 0 32rpx 40rpx;
  box-sizing: border-box;
}

/* 步骤头部 */
.step-header {
  margin-bottom: 40rpx;
}

.step-back {
  color: #666666; /* 浅色模式下的返回按钮 */
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.step-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #111111; /* 纯黑标题 */
  margin-bottom: 12rpx;
}

.step-subtitle {
  font-size: 28rpx;
  color: #666666; /* 深灰副标题 */
  line-height: 1.6;
}

/* 行业选择网格 */
.industry-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.industry-card {
  position: relative;
  width: calc(50% - 10rpx);
  min-height: 200rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
  background: #FFFFFF; /* 纯白卡片 */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03); /* 轻柔阴影 */
  box-sizing: border-box;
  transition: all 0.25s ease;
}

.industry-active {
  border-color: rgba(46, 107, 255, 0.4);
  background: rgba(46, 107, 255, 0.04);
  box-shadow: 0 12rpx 32rpx rgba(46, 107, 255, 0.1);
}

.industry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(46, 107, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.industry-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #222222; /* 黑色行业名 */
  margin-bottom: 8rpx;
}

.industry-tag {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}

.industry-check {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #2E6BFF;
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 阶段选择列表 */
.stage-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.stage-card {
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(0,0,0,0.04);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  transition: all 0.25s ease;
}

.stage-active {
  background: rgba(46, 107, 255, 0.04);
  border-color: rgba(46, 107, 255, 0.4);
}

.stage-content {
  flex: 1;
}

.stage-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 8rpx;
}

.stage-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #666666;
}

.stage-check {
  width: 48rpx;
  text-align: right;
  font-size: 36rpx;
  color: #2E6BFF;
}

/* 底部操作区 */
.step-action {
  margin-top: 40rpx;
  padding: 0 10rpx;
}

/* 确认按钮样式 */
.primary-btn {
  background: #2E6BFF;
  color: #FFFFFF;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(46, 107, 255, 0.25);
  transition: all 0.2s ease;
}

.primary-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.tap-scale {
  transform: scale(0.975);
}