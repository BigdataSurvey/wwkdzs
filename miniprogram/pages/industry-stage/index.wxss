/* ======== 全局背景层 ======== */
.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.step-page { position: relative; z-index: 1; overflow: hidden; padding: 0; min-height: 100vh; color: #333; }

/* ======== 1. 顶部进度条 ======== */
.progress-header { padding: 40rpx 40rpx 20rpx; text-align: center; }
.progress-title { font-size: 38rpx; font-weight: 700; color: #111; margin-bottom: 30rpx; }
.progress-bar-container { width: 60%; height: 8rpx; background: #E5E7EB; border-radius: 999rpx; margin: 0 auto 16rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; background: #2E6BFF; border-radius: 999rpx; transition: width 0.4s ease; }
.progress-labels { display: flex; justify-content: space-between; width: 66%; margin: 0 auto; font-size: 26rpx; color: #888888; font-weight: 600; }
.label-active { color: #1A4BFF; font-weight: 800; text-shadow: 0 2rpx 8rpx rgba(46, 107, 255, 0.2); }

.step-container { display: flex; width: 200%; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
.step-panel { width: 50%; padding: 0 32rpx 40rpx; box-sizing: border-box; }
.step-subtitle-strong { font-size: 26rpx; color: #555555; text-align: center; margin-bottom: 40rpx; font-weight: 500; }

/* ======== 2. 行业网格 ======== */
.industry-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.industry-card {
  position: relative; width: 48%; margin-bottom: 24rpx; min-height: 200rpx; padding: 28rpx;
  border-radius: 24rpx; border: 2rpx solid transparent; background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); box-sizing: border-box;
  /* 确保卡片本身绝对不发生形变 */
  transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}
.industry-active { border-color: #2E6BFF; background: #F0F7FF; box-shadow: 0 12rpx 32rpx rgba(46,107,255,0.15); }
.industry-icon { width: 72rpx; height: 72rpx; border-radius: 20rpx; background: #F3F4F6; display: flex; align-items: center; justify-content: center; font-size: 32rpx; margin-bottom: 20rpx; transition: background-color 0.2s ease; }
.industry-active .industry-icon { background: rgba(46,107,255,0.15); }
.industry-name { font-size: 32rpx; font-weight: 700; color: #111; margin-bottom: 8rpx; }
.industry-tag { font-size: 22rpx; color: #888; line-height: 1.4; }

/* ======== 3. 悬浮胶囊返回按钮 ======== */
.breadcrumb-pro {
  display: inline-flex; align-items: center; background: #FFFFFF; padding: 12rpx 32rpx 12rpx 16rpx;
  border-radius: 999rpx; margin-bottom: 40rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); border: 1rpx solid rgba(0,0,0,0.02);
}
.bc-icon-wrap { width: 48rpx; height: 48rpx; border-radius: 50%; background: #F0F5FF; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.bc-arrow { font-size: 28rpx; color: #2E6BFF; font-weight: bold; margin-top: -4rpx; }
.bc-text { font-size: 28rpx; color: #333333; font-weight: 600; }
.bc-highlight { color: #2E6BFF; margin-left: 8rpx; font-weight: 700; }

/* ======== 4. 场景化阶段卡片 ======== */
.stage-list { display: flex; flex-direction: column; gap: 24rpx; }
.stage-card-pro {
  position: relative; background: #FFF; border: 2rpx solid transparent; border-radius: 24rpx;
  padding: 32rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
  transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}
.stage-active-pro { border-color: #2E6BFF; background: #F5F9FF; box-shadow: 0 16rpx 40rpx rgba(46,107,255,0.1); }

.sc-header { display: flex; align-items: center; margin-bottom: 20rpx; }
.sc-title { font-size: 34rpx; font-weight: 700; color: #111; display: flex; align-items: center; }
.sc-icon { font-size: 40rpx; margin-right: 12rpx; }

.sc-divider { height: 1rpx; background: #F3F4F6; margin-bottom: 20rpx; }
.stage-active-pro .sc-divider { background: rgba(46,107,255,0.1); }
.sc-desc { font-size: 28rpx; color: #444; line-height: 1.5; margin-bottom: 16rpx; font-weight: 500; }
.sc-scenario-grey { font-size: 24rpx; color: #666666; background: #F3F4F6; display: inline-block; padding: 8rpx 20rpx; border-radius: 12rpx; font-weight: 500; border: 1rpx solid #E5E7EB; }

/* ======== 🚨 核心爆发：纯净的 GPU 级平滑入场，告别“抽搐抖动” ======== */
.check-marker {
  position: absolute; top: 20rpx; right: 20rpx; width: 44rpx; height: 44rpx;
  border-radius: 50%; background: #2E6BFF; color: #FFFFFF; display: flex;
  align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold;

  /* 隐藏状态：缩放在底层，透明度为0 */
  opacity: 0;
  transform: scale(0.6);
  pointer-events: none; /* 防止遮挡 */

  /* 极简丝滑过渡：不反弹、不抽搐 */
  transition: opacity 0.2s ease-out, transform 0.2s ease-out;
}

/* 激活状态：浮出水面 */
.show-marker {
  opacity: 1;
  transform: scale(1);
}

/* ======== 5. 底部按钮与安全提示 ======== */
.step-action { margin-top: 50rpx; text-align: center; }
.safe-tips-pro { font-size: 26rpx; color: #666666; margin-bottom: 24rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; }
.safe-tips-pro::before, .safe-tips-pro::after { content: ''; width: 40rpx; height: 2rpx; background: #E5E7EB; margin: 0 20rpx; }
.safe-tips-emoji { font-size: 30rpx; margin-right: 12rpx; margin-top: -4rpx; }

.primary-btn { background: #2E6BFF; color: #FFF; padding: 28rpx 0; border-radius: 20rpx; font-size: 32rpx; font-weight: 700; box-shadow: 0 12rpx 32rpx rgba(46,107,255,0.25); transition: opacity 0.2s ease; }
.btn-hover { transform: scale(0.98); opacity: 0.9; }
.tap-scale { transform: scale(0.96); }