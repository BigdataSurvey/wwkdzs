<image class="custom-bg" src="../../images/bg.png" mode="aspectFill"></image>

<view class="page step-page">
  <view class="progress-header">
    <view class="progress-title">{{step === 1 ? '选择经营行业' : '选择经营阶段'}}</view>
    <view class="progress-bar-container">
      <view class="progress-bar-fill" style="width: {{step === 1 ? '50%' : '100%'}}"></view>
    </view>
    <view class="progress-labels">
      <text class="{{step >= 1 ? 'label-active' : ''}}">选择行业</text>
      <text class="{{step >= 2 ? 'label-active' : ''}}">确认阶段</text>
    </view>
  </view>

  <view class="step-container" style="transform: translateX({{step === 1 ? '0' : '-50%'}});">

    <view class="step-panel">
      <view class="step-subtitle-strong">不同行业的风险点、成本结构差异很大</view>
      <view class="industry-grid">
        <view class="industry-card {{selectedIndustryId === item.id ? 'industry-active' : ''}}" wx:for="{{industries}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseIndustry" hover-class="tap-scale">
          <view class="industry-icon">{{item.icon}}</view>
          <view class="industry-name">{{item.name}}</view>
          <view class="industry-tag">{{item.tag}}</view>
          <view class="industry-check" wx:if="{{selectedIndustryId === item.id}}">✓</view>
        </view>
      </view>
    </view>

    <view class="step-panel">
      <view class="breadcrumb-pro" bindtap="goBack" hover-class="tap-scale">
        <text class="bc-arrow">‹</text>
        <text class="bc-text">返回修改行业 (当前: {{selectedIndustryName}})</text>
      </view>

      <view class="stage-list">
        <view class="stage-card-pro {{selectedStageKey === item.key ? 'stage-active-pro' : ''}}" wx:for="{{stages}}" wx:key="key" data-key="{{item.key}}" bindtap="chooseStage" hover-class="tap-scale-card">
          <view class="sc-header">
            <view class="sc-title">
              <view class="sc-checkbox" wx:if="{{selectedStageKey === item.key}}">✓</view>
              <view class="sc-checkbox-empty" wx:else></view>
              <text class="sc-icon">{{item.icon}}</text>{{item.name}}
            </view>
          </view>
          <view class="sc-divider"></view>
          <view class="sc-desc">{{item.desc}}</view>
          <view class="sc-scenario-grey">{{item.scenario}}</view>
        </view>
      </view>

      <view class="step-action" wx:if="{{selectedStageKey}}">
        <view class="safe-tips">预估 3-5 分钟 · 15 道核心排雷题</view>
        <view class="primary-btn" bindtap="saveSelection" hover-class="btn-hover">确认并开始诊断</view>
      </view>
    </view>

  </view>
</view>