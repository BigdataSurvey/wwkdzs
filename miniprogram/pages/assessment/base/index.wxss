/* ======== 全局背景层 ======== */
.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.glass-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(40px); pointer-events: none; }
.assessment-page { position: relative; z-index: 2; min-height: 100vh; display: flex; flex-direction: column; }

/* ======== 顶部磨砂自定义导航 ======== */
.custom-nav { position: fixed; top: 0; left: 0; width: 100%; z-index: 99; background: transparent; }
.nav-content { height: 100%; display: flex; align-items: center; justify-content: center; position: relative; padding: 0 32rpx; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #111; }
.nav-btn-right { position: absolute; right: 32rpx; font-size: 26rpx; color: #4B5563; font-weight: 600; padding: 12rpx 28rpx; background: rgba(255,255,255,0.6); border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,0.9); box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); }

.main-content { padding: 0 40rpx 160rpx; flex: 1; }

/* ======== 进度条区 ======== */
.progress-section { margin-bottom: 60rpx; }
.progress-container-pro { height: 16rpx; background: rgba(0, 0, 0, 0.06); border-radius: 999rpx; overflow: hidden; margin-bottom: 16rpx; }
.progress-bar-pro { height: 100%; background: linear-gradient(90deg, #60A5FA 0%, #2E6BFF 100%); border-radius: 999rpx; transition: width 0.5s ease; box-shadow: 2rpx 0 8rpx rgba(46, 107, 255, 0.4); }
.step-counter-pro { font-size: 26rpx; color: #666; font-weight: 600; }
.step-num { font-size: 36rpx; font-weight: 800; color: #2E6BFF; margin: 0 4rpx; }

/* ======== 题目核心区 ======== */
.capsule-style { display: inline-flex; align-items: center; padding: 10rpx 28rpx; background: rgba(46, 107, 255, 0.1); color: #2E6BFF; font-size: 24rpx; font-weight: 700; border-radius: 12rpx; margin-bottom: 32rpx; border: 1rpx solid rgba(46, 107, 255, 0.15); }

.question-title-pro { font-size: 46rpx; font-weight: 900; color: #111; line-height: 1.4; margin-bottom: 60rpx; }

/* ======== 选项卡片 ======== */
.options-list-pro { display: flex; flex-direction: column; gap: 32rpx; }
.option-card-pro {
  display: flex; align-items: center; padding: 36rpx 36rpx;
  background: rgba(255, 255, 255, 0.85); border-radius: 28rpx; min-height: 140rpx;
  border: 2rpx solid rgba(255,255,255,0.9); box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease; box-sizing: border-box; backdrop-filter: blur(10px);
}
.option-hover-pro { transform: scale(0.97); }

.option-active-pro { border-color: #2E6BFF; background: #F5F9FF; box-shadow: 0 16rpx 48rpx rgba(46, 107, 255, 0.15); }

/* 单选框 */
.radio-box { width: 48rpx; height: 48rpx; border-radius: 50%; border: 4rpx solid #9CA3AF; margin-right: 28rpx; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; background: #FFF; flex-shrink: 0; box-sizing: border-box; }
.option-active-pro .radio-box { border-color: transparent; background: #2E6BFF; box-shadow: 0 4rpx 12rpx rgba(46, 107, 255, 0.4); }
.radio-inner { color: #FFF; font-size: 28rpx; font-weight: 900; }

.option-text-pro { flex: 1; font-size: 32rpx; color: #333; font-weight: 600; line-height: 1.5; }
.option-active-pro .option-text-pro { color: #2E6BFF; font-weight: 800; }

/* ======== 底部安全背书 ======== */
.footer-action-area { position: fixed; bottom: env(safe-area-inset-bottom, 40rpx); left: 0; width: 100%; display: flex; justify-content: center; z-index: 10; pointer-events: none; }
.safe-tips-pro { display: inline-flex; align-items: center; font-size: 22rpx; color: #6B7280; font-weight: 600; background: rgba(255,255,255,0.6); padding: 12rpx 32rpx; border-radius: 999rpx; backdrop-filter: blur(10px); border: 1rpx solid rgba(255,255,255,0.6); }
.safe-tips-icon { color: #4B5563; margin-right: 10rpx; font-size: 24rpx; }

/* ======== 空状态 ======== */
.empty-state { text-align: center; padding-top: 200rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 30rpx; }
.empty-text { font-size: 30rpx; color: #666; margin-bottom: 50rpx; }
.empty-btn { display: inline-block; background: #2E6BFF; color: #FFF; padding: 20rpx 60rpx; border-radius: 999rpx; font-weight: bold; }