.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.glass-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(40px); pointer-events: none; }
.result-page { position: relative; z-index: 2; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

.custom-nav { position: absolute; top: 0; left: 0; width: 100%; z-index: 99; background: transparent; }
.nav-content { height: 100%; display: flex; align-items: center; justify-content: center; position: relative; padding: 0 32rpx; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #111; }
/* 导航图标规范化 */
.nav-icon-btn { position: absolute; width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(255,255,255,0.75); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,0.9); box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.icon-arrow { font-size: 36rpx; font-weight: 500; color: #333; margin-top: -4rpx; }
.icon-refresh { font-size: 34rpx; font-weight: 700; color: #333; }
.nav-btn-left { left: 32rpx; }
.nav-btn-right { right: 32rpx; }

.main-scroll { flex: 1; height: 100%; box-sizing: border-box; padding: 0 32rpx; }

/* 顶级毛玻璃卡片基类 */
.glass-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.04), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
}

/* 概览区 */
.overview-card { display: flex; flex-direction: column; align-items: center; padding-top: 50rpx; }
.level-badge { font-size: 26rpx; font-weight: 800; padding: 12rpx 36rpx; border-radius: 999rpx; margin-bottom: 30rpx; border: 1rpx solid currentColor; }
.score-display { margin-bottom: 20rpx; display: flex; align-items: baseline; }
.score-num { font-size: 120rpx; font-weight: 900; font-family: 'DIN Alternate', sans-serif; line-height: 1; letter-spacing: -2rpx; text-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.25); }
.score-total { font-size: 28rpx; color: #888; font-weight: 600; margin-left: 12rpx; }
/* 来源加深，位置下移不抢戏 */
.source-tag { font-size: 24rpx; color: #6B7280; margin-bottom: 50rpx; font-weight: 600; background: rgba(0,0,0,0.03); padding: 8rpx 24rpx; border-radius: 999rpx; }

/* 按钮权重重构 */
.action-row { display: flex; gap: 24rpx; width: 100%; }
.btn-primary-glass, .btn-secondary-glass { flex: 1; text-align: center; padding: 26rpx 0; border-radius: 24rpx; font-size: 30rpx; font-weight: 700; transition: all 0.2s; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); }
.btn-primary-glass { background: #2E6BFF; color: #FFF; box-shadow: 0 8rpx 24rpx rgba(46,107,255,0.3); }
/* 幽灵按钮，极低存在感 */
.btn-secondary-glass { background: rgba(255,255,255,0.6); color: #4B5563; border: 1rpx solid #E5E7EB; }

/* 解读区规范化 */
.card-title { font-size: 34rpx; font-weight: 800; color: #111; margin-bottom: 30rpx; }
.info-block { margin-bottom: 36rpx; }
.info-block:last-child { margin-bottom: 0; }
.info-sub-title { display: flex; align-items: center; font-size: 30rpx; font-weight: 800; color: #111; margin-bottom: 12rpx; }
/* 统一 Emoji 滤镜色调偏蓝灰 */
.info-emoji { filter: hue-rotate(200deg) saturate(0.8); margin-right: 12rpx; font-size: 32rpx; }
.card-desc { font-size: 28rpx; color: #4B5563; line-height: 1.6; font-weight: 500; }

/* 隐患列表区 */
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.header-link { font-size: 24rpx; color: #2E6BFF; font-weight: 600; }
.issue-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.03); }
.issue-item:last-child { border-bottom: none; padding-bottom: 0; }
.issue-text { font-size: 28rpx; color: #333; font-weight: 600; }
.issue-tag { font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 8rpx; font-weight: 800; }

.tag-high { color: #FF4D4F; background: #FFF1F0; border: 1rpx solid #FFA39E; }
.tag-mid { color: #FAAD14; background: #FFFBE6; border: 1rpx solid #FFE58F; }
.tag-grey { color: #9CA3AF; background: #F3F4F6; border: 1rpx solid #E5E7EB; }

/* 🚨 PRO卡片：剥离突兀紫色，回归蓝白高奢体系 */
.promo-card { display: flex; align-items: center; justify-content: space-between; background: linear-gradient(135deg, rgba(240,245,255,0.9) 0%, rgba(220,230,255,0.95) 100%); border-color: rgba(46,107,255,0.1); }
.promo-content { flex: 1; }
.promo-title { font-size: 32rpx; font-weight: 800; color: #111; margin-bottom: 10rpx; }
.promo-crown { filter: hue-rotate(-20deg) saturate(1.5); }
.promo-desc { font-size: 24rpx; color: #6B7280; font-weight: 500; }
.promo-btn { background: #2E6BFF; color: #FFF; font-size: 26rpx; font-weight: 700; padding: 18rpx 36rpx; border-radius: 999rpx; box-shadow: 0 8rpx 24rpx rgba(46,107,255,0.3); }