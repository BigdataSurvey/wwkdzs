/* 红色报警态：空胶囊样式 */
.capsule-empty { 
  background: rgba(255, 77, 79, 0.05) !important; 
  border: 2rpx solid rgba(255, 77, 79, 0.3) !important; 
}
.capsule-empty .capsule-text { color: #FF4D4F !important; }

/* 🚨 经典抖动动画 */
@keyframes shake-horizontal {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-8rpx); }
  20%, 40%, 60%, 80% { transform: translateX(8rpx); }
}

.shake { 
  animation: shake-horizontal 0.4s ease-in-out; 
  background: #FFF1F0 !important;
  border-color: #FF4D4F !important;
}