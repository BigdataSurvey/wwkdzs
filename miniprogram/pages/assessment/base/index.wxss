.progress-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 10rpx;
}

.progress-ring {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: linear-gradient(135deg, #2E6BFF 0%, #6EA0FF 100%);
  box-shadow: 0 16rpx 40rpx rgba(46, 107, 255, 0.24);
}

.progress-ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #0B1731;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
}

.ring-num {
  font-size: 40rpx;
  font-weight: 800;
}

.ring-total {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(219,229,245,0.76);
}

.progress-side {
  flex: 1;
}

.progress-side-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.progress-side-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(219, 229, 245, 0.78);
}

.question-title {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #FFFFFF;
}

.question-desc {
  margin: 16rpx 0 28rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(219, 229, 245, 0.78);
}

.option-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.option-active {
  background: rgba(46, 107, 255, 0.16);
  border-color: rgba(92, 144, 255, 0.48);
  box-shadow: 0 16rpx 40rpx rgba(46, 107, 255, 0.12);
}

.option-index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.08);
  color: #DDE9FF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #FFFFFF;
}

.option-check {
  width: 44rpx;
  text-align: right;
  font-size: 30rpx;
  color: #BFD4FF;
}

.action-row {
  display: flex;
  justify-content: space-between;
}

.action-btn {
  width: 48.2%;
}

.submit-btn {
  letter-spacing: 1rpx;
}

/* 锁定行业标签 */
.locked-industry {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.06);
  font-size: 24rpx;
  color: #A0AAB5;
}

.lock-icon {
  font-size: 22rpx;
}

/* 进度条 */
.progress-card {
  margin-bottom: 4rpx;
}

.progress-bar-wrap {
  height: 10rpx;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.08);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #2E6BFF 0%, #5790FF 100%);
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ======== 生成报告 - 全屏遮罩 ======== */
.generating-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(8, 26, 57, 0.92);
  backdrop-filter: blur(12rpx);
}

.generating-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

/* 雷达扫描旋转环 */
.generating-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(46, 107, 255, 0.15);
  border-top-color: #2E6BFF;
  border-right-color: rgba(46, 107, 255, 0.55);
  animation: radar-spin 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  box-shadow:
    0 0 40rpx rgba(46, 107, 255, 0.25),
    inset 0 0 30rpx rgba(46, 107, 255, 0.08);
}

@keyframes radar-spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.generating-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  animation: text-pulse 1.8s ease-in-out infinite;
}

@keyframes text-pulse {
  0%, 100% { opacity: 0.6; }
  50%      { opacity: 1; }
}
