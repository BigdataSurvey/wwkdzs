.field-line,
.result-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.field-line:last-child,
.result-line:last-child {
  border-bottom: none;
}

.field-label {
  width: 44%;
  font-size: 27rpx;
  color: #E8F1FF;
}

.field-input {
  width: 48%;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.06);
  color: #FFFFFF;
  text-align: right;
}

.result-line {
  font-size: 28rpx;
  color: #E8F1FF;
}

.strong-line {
  font-weight: 700;
  color: #FFFFFF;
}

.result-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(219, 229, 245, 0.78);
}
