.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.cashflow-page { position: relative; z-index: 1; min-height: 100vh; padding: 80rpx 32rpx; display: flex; align-items: center; justify-content: center; }
.coming-soon-card {
  background: rgba(255,255,255,0.9); backdrop-filter: blur(24px); border-radius: 36rpx;
  padding: 72rpx 48rpx; text-align: center; width: 100%;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(255,255,255,0.9);
}
.coming-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.coming-title { font-size: 40rpx; font-weight: 800; color: #111; margin-bottom: 16rpx; }
.coming-desc { font-size: 28rpx; color: #888; line-height: 1.6; margin-bottom: 36rpx; }
.coming-status { display: inline-flex; align-items: center; gap: 10rpx; font-size: 24rpx; color: #8B5CF6; font-weight: 600; margin-bottom: 48rpx; padding: 8rpx 24rpx; background: rgba(139,92,246,0.06); border-radius: 999rpx; }
.coming-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #8B5CF6; }
.coming-btn { display: inline-block; background: linear-gradient(135deg, #8B5CF6, #6D28D9); color: #FFF; font-size: 28rpx; font-weight: 700; padding: 24rpx 64rpx; border-radius: 999rpx; box-shadow: 0 12rpx 32rpx rgba(139,92,246,0.3); }
.coming-btn-active { transform: scale(0.96); opacity: 0.9; }
