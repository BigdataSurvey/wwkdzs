.tools-hero {
  background: linear-gradient(135deg, rgba(8, 108, 146, 0.95) 0%, rgba(46, 107, 255, 0.88) 100%);
}

.tool-list-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.08) 100%);
  border-radius: 30rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 18rpx 44rpx rgba(0,0,0,0.16);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.tool-list-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.tool-list-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.tool-list-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(219, 229, 245, 0.76);
  margin-bottom: 22rpx;
}

.tool-list-link {
  color: #BFD4FF;
  font-size: 28rpx;
  font-weight: 700;
}
