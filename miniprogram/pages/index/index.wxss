/* ======== 首页 · 全面重构 ======== */

/* 页面容器 */
.home-page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 28rpx 0;
  overflow: hidden;
}

/* ======== 暗光晕背景装饰 ======== */
.glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  filter: blur(120rpx);
}

.glow-blue {
  top: -160rpx;
  right: -100rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle, rgba(46, 107, 255, 0.18) 0%, transparent 70%);
}

.glow-purple {
  bottom: 300rpx;
  left: -140rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(120, 80, 220, 0.10) 0%, transparent 70%);
}

/* ======== 行业水印 ======== */
.industry-watermark {
  position: absolute;
  top: 80rpx;
  right: -40rpx;
  width: 420rpx;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 0;
  opacity: 0;
  transition: opacity 0.8s ease;
}

.industry-watermark.visible {
  opacity: 1;
}

.industry-watermark text {
  font-size: 360rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.018);
  transform: rotate(-18deg);
  line-height: 1;
  user-select: none;
}

/* ======== ① 情绪大标题 ======== */
.headline-section {
  position: relative;
  z-index: 1;
  padding: 48rpx 0 24rpx;
}

.headline-line1 {
  font-size: 44rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.4;
  letter-spacing: 2rpx;
}

.headline-line2 {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.35;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

.hl-brand {
  color: #4D8EFF;
  background: linear-gradient(135deg, #2E6BFF 0%, #60A5FA 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ======== ② 胶囊按钮 ======== */
.capsule-row {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 40rpx;
}

.capsule {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
  transition: all 0.25s ease;
}

.capsule-icon {
  font-size: 28rpx;
}

.capsule-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 500;
}

/* 抖动动画 */
@keyframes shake-horizontal {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-8rpx); }
  20%, 40%, 60%, 80% { transform: translateX(8rpx); }
}

.shake {
  animation: shake-horizontal 0.5s ease-in-out;
}

/* ======== ③ 功能卡片通用 ======== */
.feature-card {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.card-body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-content {
  flex: 1;
}

.card-main-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.card-sub-title {
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.5;
}

/* ======== 3D 图标 ======== */
.card-icon-wrap {
  flex-shrink: 0;
}

.icon-3d {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.icon-inner {
  font-size: 42rpx;
  position: relative;
  z-index: 1;
}

/* 盾牌图标 — 呼吸蓝光 */
.icon-shield {
  background: linear-gradient(135deg, rgba(46, 107, 255, 0.20) 0%, rgba(46, 107, 255, 0.08) 100%);
  border: 1rpx solid rgba(46, 107, 255, 0.25);
  box-shadow: 0 8rpx 32rpx rgba(46, 107, 255, 0.18);
  animation: breathe-blue 3s ease-in-out infinite;
}

@keyframes breathe-blue {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(46, 107, 255, 0.18); }
  50%      { box-shadow: 0 12rpx 48rpx rgba(46, 107, 255, 0.35); }
}

/* 锁头图标 */
.icon-lock {
  background: linear-gradient(135deg, rgba(180, 160, 120, 0.12) 0%, rgba(180, 160, 120, 0.05) 100%);
  border: 1rpx solid rgba(180, 160, 120, 0.18);
}

/* AI 图标 */
.icon-ai {
  background: linear-gradient(135deg, rgba(120, 80, 220, 0.18) 0%, rgba(46, 107, 255, 0.10) 100%);
  border: 1rpx solid rgba(120, 80, 220, 0.22);
  box-shadow: 0 8rpx 32rpx rgba(120, 80, 220, 0.12);
}

/* ======== C位卡片：基础排雷体检 ======== */
.card-primary {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(46, 107, 255, 0.04) 100%);
  border-color: rgba(46, 107, 255, 0.15);
  padding-bottom: 24rpx;
}

.card-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(60rpx);
}

.card-glow-blue {
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(46, 107, 255, 0.12);
}

/* 渐变流光按钮 */
.shimmer-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #2E6BFF 0%, #5790FF 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(46, 107, 255, 0.30);
}

.shimmer-light {
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.20) 50%,
    transparent 100%
  );
  animation: shimmer-sweep 3s ease-in-out infinite;
}

@keyframes shimmer-sweep {
  0%   { left: -100%; }
  40%  { left: 120%; }
  100% { left: 120%; }
}

/* ======== 次级卡片：深度诊断（锁定态）======== */
.card-locked {
  background: rgba(255, 255, 255, 0.03);
  opacity: 0.65;
}

.lock-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(212, 180, 100, 0.20) 0%, rgba(212, 180, 100, 0.08) 100%);
  border: 1rpx solid rgba(212, 180, 100, 0.30);
  color: #D4B464;
  font-size: 22rpx;
  font-weight: 600;
}

/* ======== 工具卡片：AI 经营大脑（极光渐变）======== */
.card-aurora {
  background: linear-gradient(135deg, rgba(120, 80, 220, 0.10) 0%, rgba(46, 107, 255, 0.08) 50%, rgba(100, 200, 255, 0.05) 100%);
  border-color: rgba(120, 80, 220, 0.15);
}

.hot-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(239, 68, 68, 0.16);
  border: 1rpx solid rgba(239, 68, 68, 0.28);
  color: #F87171;
  font-size: 22rpx;
  font-weight: 600;
}

/* ======== 触摸反馈 ======== */
.tap-scale {
  transform: scale(0.975);
  opacity: 0.92;
}
