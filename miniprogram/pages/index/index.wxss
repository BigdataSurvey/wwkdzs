/* ======== 全局背景层 ======== */
.custom-bg {
  position: fixed; /* 保证上下滑动时背景图纹丝不动，更高级 */
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0; /* 极其关键：刚好浮在纯灰底色之上 */
  opacity: 1;
}

/* 页面基础布局 */
.home-page {
  position: relative;
  z-index: 1; /* 极其关键：确保所有卡片稳稳压在背景图上面 */
  min-height: 100vh;
  padding: 40rpx 32rpx 0;
  overflow: hidden;
  box-sizing: border-box;
}

/* ======== 1. 情绪大标题 (亮色反转) ======== */
.headline-section {
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

.headline-line1 {
  font-size: 40rpx;
  color: #666666; /* 浅色模式使用深灰，高级不刺眼 */
  margin-bottom: 12rpx;
}

.headline-line2 {
  font-size: 52rpx;
  font-weight: 800;
  color: #111111; /* 主标题纯黑，强化焦点 */
  letter-spacing: 2rpx;
}

.hl-brand {
  color: #2E6BFF; /* 品牌蓝 */
}

/* ======== 2. 胶囊按钮区 (灵动岛风格) ======== */
.capsule-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 50rpx;
}

.capsule {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0,0,0,0.03);
  transition: all 0.2s ease;
}

.capsule-text {
  font-size: 26rpx;
  color: #555555;
  font-weight: 500;
}

/* 拒绝行业的防呆抖动动画 */
@keyframes shake-horizontal {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-8rpx); }
  20%, 40%, 60%, 80% { transform: translateX(8rpx); }
}

.shake {
  animation: shake-horizontal 0.5s ease-in-out;
  border: 1rpx solid #FF4D4F !important;
  color: #FF4D4F !important;
}

/* ======== 3. 核心功能卡片通用 ======== */
.feature-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
  /* 极其轻柔的弥散阴影，营造高级悬浮感 */
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-content {
  flex: 1;
}

.card-main-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 10rpx;
}

.card-sub-title {
  font-size: 26rpx;
  color: #888888;
}

/* ======== 4. 3D 图标底座设计 ======== */
.icon-3d {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-inner {
  font-size: 48rpx;
}

/* 盾牌蓝底座 (微发光) */
.icon-shield-light {
  background: linear-gradient(135deg, #EBF1FF 0%, #F5F8FF 100%);
  box-shadow: inset 0 4rpx 10rpx #FFFFFF, 0 8rpx 20rpx rgba(46, 107, 255, 0.1);
}

/* 锁头灰金底座 */
.icon-lock-light {
  background: linear-gradient(135deg, #F8F9FA 0%, #F1F3F5 100%);
  box-shadow: inset 0 4rpx 10rpx #FFFFFF;
}

/* AI紫底座 */
.icon-ai-light {
  background: linear-gradient(135deg, #F3E8FF 0%, #FAEDFF 100%);
  box-shadow: inset 0 4rpx 10rpx #FFFFFF, 0 8rpx 20rpx rgba(168, 85, 247, 0.1);
}

/* ======== 5. 按钮与角标 ======== */
/* C位大按钮 */
.shimmer-btn-light {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #2E6BFF;
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 32rpx;
  box-shadow: 0 12rpx 24rpx rgba(46, 107, 255, 0.25);
}

/* 未解锁卡片 (磨砂半透明变灰) */
.card-locked-light {
  opacity: 0.85;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10px);
}

.lock-tag-light {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  font-size: 22rpx;
  color: #999999;
  background: #F0F0F0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.hot-tag-light {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  font-size: 22rpx;
  color: #FF4D4F;
  background: #FFF1F0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

/* ======== 6. 交互点击下压回弹 (极其爽脆) ======== */
.tap-scale {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}