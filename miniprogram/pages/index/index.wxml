<image class="custom-bg" src="../../images/bg.png" mode="aspectFill"></image>

<view class="page home-page">

  <view class="headline-section">
    <view class="headline-sub">真金白银砸下去之前</view>
    <view class="headline-main">
      先摸清你的<text class="hl-gradient">盈利底牌</text>
    </view>
  </view>

  <view class="capsule-row">
    <view class="capsule-primary {{!selection.industryId ? 'capsule-empty pulse-infinite' : 'capsule-solid'}} {{shakeIndustry ? 'shake' : ''}}" bindtap="goSelectIndustry" hover-class="tap-scale">
      <text class="capsule-icon">🎯</text>
      <text class="capsule-text">{{selectionDisplayText}}</text>
    </view>

    <view class="capsule-ghost" bindtap="goArchive" hover-class="tap-scale">
      <text class="capsule-icon-ghost">📊</text>
      <text class="capsule-text-ghost">{{diagnosisCount || 0}}次体检</text>
    </view>
  </view>

  <view class="feature-card card-primary-light" bindtap="goBaseAssessment" hover-class="tap-scale">
    <view class="card-body">
      <view class="card-icon-wrap">
        <view class="icon-3d icon-shield-light"><text class="icon-inner">🛡️</text></view>
      </view>
      <view class="card-content">
        <view class="card-main-title">基础排雷体检</view>
        <view class="card-sub-title">15道核心题，测算踩坑概率</view>
      </view>
    </view>
    <view class="shimmer-btn-light"><text>开始体检</text></view>
  </view>

  <view class="feature-card card-glassmorphism">
    <view class="card-body">
      <view class="card-icon-wrap">
        <view class="icon-3d icon-lock-light"><text class="icon-inner">🔒</text></view>
      </view>
      <view class="card-content">
        <view class="card-main-title">深度专业诊断</view>
        <view class="card-sub-title">现金流与复购率测算模型</view>
      </view>
    </view>
    <view class="lock-tag-pro">🔒 完成体检后解锁</view>
  </view>

  <view class="feature-card card-ai-light" bindtap="goTools" hover-class="tap-scale">
    <view class="card-body">
      <view class="card-icon-wrap">
        <view class="icon-3d icon-ai-light"><text class="icon-inner">🤖</text></view>
      </view>
      <view class="card-content">
        <view class="card-main-title">AI 经营大脑</view>
        <view class="card-sub-title">起名 / 写文案 / 算利润，一秒出活</view>
      </view>
    </view>
    <view class="hot-tag-light">高频</view>
  </view>

  <view style="height: 240rpx;"></view>
</view>