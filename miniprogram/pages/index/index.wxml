<image class="custom-bg" src="../../images/bg.png" mode="aspectFill"></image>

<view class="page home-page">

  <view class="headline-section">
    <!-- 动态文案：毛玻璃胶囊，单行截断 -->
    <view class="headline-sub-wrap">
      <view class="headline-sub">{{greeting}}</view>
    </view>
    
    <!-- 主标题：「先摸清你的」+「盈利底牌」翻牌，同一行 -->
    <view class="headline-main">
      <text class="hl-prefix">先摸清你的</text>
      <view class="flip-container" bindtap="flipTitle">
        <view class="flip-card {{isFlipped ? 'flipped' : ''}}">
          <view class="flip-front">
            <text class="hl-gradient">盈利底牌</text>
          </view>
          <view class="flip-back">
            <text class="hl-gradient">盈利底牌</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="capsule-row">
    <view class="capsule-primary {{!selection.industryId ? 'capsule-empty pulse-infinite' : 'capsule-solid'}} {{shakeIndustry ? 'shake' : ''}}" bindtap="goSelectIndustry" hover-class="tap-scale">
      <text class="capsule-icon">🎯</text>
      <text class="capsule-text">{{selectionDisplayText}}</text>
    </view>

    <view class="capsule-ghost" bindtap="goArchive" hover-class="tap-scale">
      <text class="capsule-icon-ghost">📊</text>
      <text class="capsule-text-ghost">{{diagnosisCount || 0}}次体检</text>
    </view>
  </view>

  <view class="feature-card card-primary-light" bindtap="goBaseAssessment" hover-class="tap-scale">
    <view class="card-body">
      <view class="card-icon-wrap">
        <view class="icon-3d icon-shield-light"><text class="icon-inner">🛡️</text></view>
      </view>
      <view class="card-content">
        <view class="card-main-title">基础排雷体检</view>
        <view class="card-sub-title">15道核心题，测算踩坑概率</view>
      </view>
    </view>
    <view class="shimmer-btn-light"><text>开始体检</text></view>
  </view>

  <view class="card-pro-apple" hover-class="{{proUnlocked ? 'tap-scale' : ''}}">
    <view class="shimmer-sweep"></view>
    <view class="card-body">
      <view class="card-icon-wrap">
        <view class="icon-lock-pro"><text class="icon-inner">👑</text></view>
      </view>
      <view class="card-content">
        <view class="pro-text-main">深度专业诊断 <text class="pro-badge-apple">PRO</text></view>
        <view class="pro-sub-text">{{proUnlocked ? '快来进行深度诊断吧！' : '现金流与复购率核心测算'}}</view>
        <view class="{{proUnlocked ? 'unlock-tag-apple' : 'lock-tag-apple'}}">{{proUnlocked ? '✅ 已解锁' : '🔒 完成基础排雷免费解锁'}}</view>
      </view>
    </view>
  </view>

  <view class="feature-card card-ai-magic" bindtap="goTools" hover-class="tap-scale">
    <view class="card-body">
      <view class="card-icon-wrap">
        <view class="icon-3d icon-ai-magic-base"><text class="icon-inner">✨</text></view>
      </view>
      <view class="card-content">
        <view class="card-main-title ai-text-gradient">AI 智能商业参谋</view>
        <view class="card-sub-title">选址 / 算账 / 营销，你的全能外脑</view>
        <view class="live-tag">
          <view class="live-dot"></view>
          <text>今日已有 {{aiUsageCount}} 人求教</text>
        </view>
      </view>
    </view>

    <view class="new-badge-magic">新功能</view>

  </view>

  <view style="height: 240rpx;"></view>
</view>