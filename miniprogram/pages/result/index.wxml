<image class="custom-bg" src="../../images/bg.png" mode="aspectFill"></image>
<view class="glass-overlay"></view>

<view class="page result-page">
  <view class="toolbar">
    <view class="toolbar-btn toolbar-btn-ghost" bindtap="reTest" hover-class="toolbar-btn-active">
      <text class="toolbar-icon">↻</text>
      <text class="toolbar-label">重新排雷</text>
    </view>
    <button class="toolbar-btn toolbar-btn-primary" open-type="share" hover-class="toolbar-btn-active">
      <text class="toolbar-icon">👥</text>
      <text class="toolbar-label">分享</text>
    </button>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="main-scroll">

    <view class="overview-card" style="border-color: {{riskBorderColor}};">
      <view class="level-badge" style="color: {{levelColor}}; background: {{levelBg}}; border-color: {{levelColor}};">
        风险等级：{{level}}
      </view>

      <view class="score-display">
        <text class="score-num" style="color: {{levelColor}};">{{displayScore}}</text>
        <text class="score-total">/ 100 分</text>
      </view>

      <view class="source-tag">{{sourceLabel}}</view>

      <view class="conclusion-block">
        <view class="conclusion-line">
          <text class="conclusion-icon">{{score < 60 ? '⚠️' : (score >= 80 ? '✅' : '⚠️')}}</text>
          <text class="conclusion-text" style="color: {{levelColor}};">结论：{{conclusion}}</text>
        </view>
        <view class="advice-line">
          <text class="advice-text">建议：{{advice}}</text>
        </view>
      </view>
    </view>

    <view class="content-card ai-card">
      <view class="card-title-row ai-header">
        <text class="card-title ai-title">✨ AI 参谋深度测算</text>
        <view class="ai-tag">通义大模型驱动</view>
      </view>

      <view class="ai-loading" wx:if="{{aiLoading}}">
        <view class="scanning-box">
          <view class="scanning-light"></view>
        </view>
        <text class="ai-loading-text">正在为您生成亿级参数的商业诊断...</text>
      </view>

      <view class="ai-content" wx:if="{{!aiLoading}}">
        <text class="ai-text">{{displayAiReport}}</text>
        <text class="ai-cursor" wx:if="{{aiReport !== displayAiReport}}">|</text>
      </view>
    </view>

    <view class="content-card">
      <view class="card-title-row">
        <text class="card-title">📊 风险结构解读</text>
      </view>

      <view class="risk-panel {{item.expanded ? 'risk-panel-open' : ''}}"
            wx:for="{{riskStructure}}" wx:key="title"
            data-idx="{{index}}" bindtap="toggleRiskPanel">
        <view class="risk-panel-header">
          <view class="risk-panel-left">
            <text class="risk-panel-icon">{{item.icon}}</text>
            <text class="risk-panel-title">{{item.title}}</text>
          </view>
          <view class="risk-panel-right">
            <text class="risk-panel-tag {{item.tagClass}}">{{item.tag}}</text>
            <text class="risk-panel-arrow {{item.expanded ? 'arrow-up' : ''}}">›</text>
          </view>
        </view>
        <view class="risk-panel-body" wx:if="{{item.expanded}}">
          <text class="risk-panel-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="content-card">
      <view class="card-title-row">
        <text class="card-title">⚠️ 关键隐患</text>
      </view>

      <view wx:for="{{issues}}" wx:key="idx" class="issue-item-wrap">
        <view wx:if="{{index < 2 || issuesUnlocked}}" class="issue-item">
          <view class="issue-header">
            <view class="issue-idx">{{item.idx}}</view>
            <text class="issue-tag {{item.tagClass}}">{{item.tagIcon}} {{item.tag}}</text>
          </view>
          <view class="issue-name">{{item.text}}</view>
          <view class="issue-detail">
            <text class="issue-consequence">后果：{{item.consequence}}</text>
            <text class="issue-suggestion">建议：{{item.suggestion}}</text>
          </view>
        </view>

        <view wx:if="{{index >= 2 && !issuesUnlocked}}" class="issue-item issue-locked">
          <view class="issue-header">
            <view class="issue-idx issue-idx-locked">{{item.idx}}</view>
            <text class="issue-tag itag-grey">⚪ 未解锁</text>
          </view>
          <view class="issue-name issue-name-blur">{{item.text}}</view>
          <view class="issue-lock-mask">
            <text class="lock-mask-text">🔒 分享给好友即可解锁全部隐患</text>
          </view>
        </view>
      </view>

      <view class="unlock-share-row" wx:if="{{!issuesUnlocked}}">
        <button class="unlock-share-btn" open-type="share" hover-class="unlock-share-btn-active">
          <text>👥 分享解锁全部隐患</text>
        </button>
      </view>
    </view>

    <view class="pro-card" bindtap="onUnlockPro" hover-class="pro-card-active">
      <view class="pro-content">
        <view class="pro-title">
          <text class="pro-crown">👑</text>
          <text> 深度专业诊断 PRO</text>
        </view>
        <view class="pro-desc">获取完整建议与备选三件套</view>
      </view>
      <view class="pro-btn">解锁完整版</view>
    </view>

    <view style="height: 160rpx;"></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="bottom-bar-btn" bindtap="onSaveImage" hover-class="bottom-bar-btn-active">
      <text class="bottom-bar-icon">📷</text>
      <text class="bottom-bar-label">保存结果</text>
    </view>
    <button class="bottom-bar-btn bottom-bar-share-btn" open-type="share" hover-class="bottom-bar-btn-active">
      <text class="bottom-bar-icon">👥</text>
      <text class="bottom-bar-label">分享好友</text>
    </button>
    <view class="bottom-bar-btn bottom-bar-pro-btn" bindtap="onUnlockPro" hover-class="bottom-bar-btn-active">
      <text class="bottom-bar-icon">🔓</text>
      <text class="bottom-bar-label">解锁 PRO</text>
    </view>
  </view>
</view>