<image class="custom-bg" src="../../images/bg.png" mode="aspectFill"></image>
<view class="glass-overlay"></view>

<view class="page result-page">

  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navHeight}}px;">
    <view class="nav-content">
      <view class="nav-btn-left" bindtap="goHome">返回首页</view>
      <view class="nav-title">诊断结果</view>
      <view class="nav-btn-right" bindtap="reTest">重做</view>
    </view>
  </view>

  <view class="main-content" style="margin-top: {{statusBarHeight + navHeight + 20}}px;">

    <view class="glass-card overview-card">
      <view class="level-badge" style="color: {{levelColor}}; background: {{levelColor}}15;">
        风险等级：{{level}}
      </view>
      <view class="score-display">
        <text class="score-num" style="color: {{levelColor}};">{{score}}</text>
        <text class="score-total">/ 100 分</text>
      </view>
      <view class="tags-row">
        <text class="tag-item">行业诊断</text>
        <text class="tag-item">基础排雷</text>
      </view>
      <view class="action-row">
        <view class="btn-primary-glass" style="background: {{levelColor}}15; color: {{levelColor}}; border-color: {{levelColor}}30;">建议暂缓投入</view>
        <view class="btn-secondary-glass">查看详细方案</view>
      </view>
    </view>

    <view class="glass-card info-card">
      <view class="card-title">📝 风险解读</view>
      <view class="card-desc">您的启动资金存在较大缺口或高杠杆风险，在行业平均回本周期内，极易引发资金链断裂。建议增加自有备用金储备。</view>
    </view>

    <view class="glass-card list-card">
      <view class="card-header">
        <view class="card-title">⚠️ 三个关键隐患</view>
        <view class="header-link">查看全部 ›</view>
      </view>
      <view class="issue-item">
        <view class="issue-dot" style="background: #FF4D4F;"></view>
        <view class="issue-text">启动资金依赖借贷</view>
        <view class="issue-tag" style="color: #FF4D4F; background: #FFF1F0;">偏高</view>
      </view>
      <view class="issue-item">
        <view class="issue-dot" style="background: #F59E0B;"></view>
        <view class="issue-text">行业经验不足</view>
        <view class="issue-tag" style="color: #F59E0B; background: #FEF3C7;">较高</view>
      </view>
      <view class="issue-item">
        <view class="issue-dot" style="background: #9CA3AF;"></view>
        <view class="issue-text">选址客流风险</view>
        <view class="issue-tag" style="color: #6B7280; background: #F3F4F6;">待评估</view>
      </view>
    </view>

    <view class="glass-card promo-card">
      <view class="promo-content">
        <view class="promo-title">👑 深度专业诊断 PRO</view>
        <view class="promo-desc">获取完整建议与备选三件套</view>
      </view>
      <view class="promo-btn">解锁完整版</view>
    </view>

  </view>
</view>