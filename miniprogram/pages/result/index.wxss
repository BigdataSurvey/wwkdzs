.result-hero {
  background: linear-gradient(135deg, rgba(46,107,255,0.94) 0%, rgba(42,91,205,0.88) 100%);
}

.tone-orange {
  background: linear-gradient(135deg, rgba(225, 114, 64, 0.94) 0%, rgba(172, 80, 45, 0.88) 100%);
}

.tone-green {
  background: linear-gradient(135deg, rgba(22, 163, 74, 0.92) 0%, rgba(13, 148, 136, 0.86) 100%);
}

.summary-text,
.action-item {
  font-size: 28rpx;
  line-height: 1.7;
  color: #EAF1FF;
}

.dimension-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.dimension-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.dimension-label {
  font-size: 28rpx;
  color: #FFFFFF;
}

.action-item {
  margin-top: 14rpx;
}

.action-card {
  min-height: 150rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.action-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.action-card-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(219, 229, 245, 0.76);
}
