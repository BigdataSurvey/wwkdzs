.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.glass-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(40px); pointer-events: none; }
.result-page { position: relative; z-index: 2; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

.custom-nav { position: absolute; top: 0; left: 0; width: 100%; z-index: 99; background: transparent; }
.nav-content { height: 100%; display: flex; align-items: center; justify-content: center; position: relative; padding: 0 32rpx; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #111; }
/* 🚨 圆形图标按钮，极其优雅 */
.nav-icon-btn { position: absolute; width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #333; border: 1rpx solid rgba(255,255,255,0.9); box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); font-weight: 900; }
.nav-btn-left { left: 32rpx; }
.nav-btn-right { right: 32rpx; }

/* 允许整体滚动 */
.main-scroll { flex: 1; height: 100%; box-sizing: border-box; padding: 0 32rpx; }

/* 玻璃态高定卡片：加大了外边距，拉开了层次 */
.glass-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.04), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
}

/* 概览卡片 */
.overview-card { display: flex; flex-direction: column; align-items: center; padding-top: 50rpx; }
.level-badge { font-size: 28rpx; font-weight: 800; padding: 12rpx 36rpx; border-radius: 999rpx; margin-bottom: 24rpx; border: 1rpx solid currentColor; }
.score-display { margin-bottom: 16rpx; display: flex; align-items: baseline; }
.score-num { font-size: 110rpx; font-weight: 900; font-family: 'DIN Alternate', sans-serif; line-height: 1; letter-spacing: -2rpx; }
.score-total { font-size: 28rpx; color: #888; font-weight: 600; margin-left: 12rpx; }
.source-tag { font-size: 24rpx; color: #9CA3AF; margin-bottom: 50rpx; font-weight: 500; }

.action-row { display: flex; gap: 24rpx; width: 100%; }
.btn-primary-glass, .btn-secondary-glass { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 20rpx; font-size: 28rpx; font-weight: 700; transition: all 0.2s; }
/* 主按钮蓝色，副按钮警示色 */
.btn-primary-glass { background: #2E6BFF; color: #FFF; box-shadow: 0 8rpx 24rpx rgba(46,107,255,0.3); }

/* 解读卡片分层 */
.card-title { font-size: 32rpx; font-weight: 800; color: #111; margin-bottom: 30rpx; }
.info-block { margin-bottom: 30rpx; }
.info-block:last-child { margin-bottom: 0; }
.info-sub-title { font-size: 28rpx; font-weight: 700; color: #333; margin-bottom: 10rpx; }
.card-desc { font-size: 26rpx; color: #4B5563; line-height: 1.6; font-weight: 500; }

/* 🚨 规范化的隐患列表体系 */
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.header-link { font-size: 24rpx; color: #2E6BFF; font-weight: 600; }
.issue-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.04); }
.issue-item:last-child { border-bottom: none; padding-bottom: 0; }
.issue-text { font-size: 28rpx; color: #333; font-weight: 600; }
.issue-tag { font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 8rpx; font-weight: 800; }

/* 严格色阶体系 */
.tag-high { color: #FF4D4F; background: #FFF1F0; border: 1rpx solid #FFA39E; }
.tag-mid { color: #FAAD14; background: #FFFBE6; border: 1rpx solid #FFE58F; }
.tag-grey { color: #9CA3AF; background: #F3F4F6; border: 1rpx solid #E5E7EB; }

/* 升级卡片 */
.promo-card { display: flex; align-items: center; justify-content: space-between; background: linear-gradient(135deg, rgba(245,243,255,0.85) 0%, rgba(237,233,254,0.95) 100%); border-color: rgba(139,92,246,0.2); }
.promo-title { font-size: 30rpx; font-weight: 800; color: #111; margin-bottom: 8rpx; }
.promo-desc { font-size: 24rpx; color: #6B7280; font-weight: 500;}
.promo-btn { background: #8B5CF6; color: #FFF; font-size: 24rpx; font-weight: 700; padding: 16rpx 32rpx; border-radius: 999rpx; box-shadow: 0 8rpx 20rpx rgba(139,92,246,0.3); }