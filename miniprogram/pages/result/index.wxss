/* ======== 背景层 ======== */
.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.glass-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1; background: rgba(255,255,255,0.5); backdrop-filter: blur(40px); pointer-events: none; }
.result-page { position: relative; z-index: 2; min-height: 100vh; display: flex; flex-direction: column; }

/* ======== 顶部工具栏 ======== */
.toolbar {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 32rpx;
}
.toolbar-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.toolbar-btn-ghost {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  color: #666;
}
.toolbar-btn-primary {
  background: linear-gradient(135deg, #2E6BFF, #1A4BFF);
  color: #FFF;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(46,107,255,0.3);
  margin: 0; padding: 12rpx 28rpx; line-height: inherit;
  animation: share-breathe 3s ease-in-out infinite;
}
.toolbar-btn-primary::after { display: none; }
@keyframes share-breathe {
  0%, 100% { box-shadow: 0 8rpx 20rpx rgba(46,107,255,0.3); }
  50% { box-shadow: 0 8rpx 28rpx rgba(46,107,255,0.5); }
}
.toolbar-icon { font-size: 28rpx; }
.toolbar-label { font-size: 24rpx; font-weight: 600; }
.toolbar-btn-active { opacity: 0.7; transform: scale(0.96); }

/* ======== 滚动区 ======== */
.main-scroll {
  flex: 1;
  padding: 0 32rpx;
  -webkit-overflow-scrolling: touch;
}

/* ======== 核心概览卡 ======== */
.overview-card {
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(24px);
  border: 2rpx solid rgba(0,0,0,0.04);
  border-radius: 36rpx;
  padding: 56rpx 40rpx 48rpx;
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.04), inset 0 2rpx 8rpx rgba(255,255,255,0.8);
}

.level-badge {
  font-size: 26rpx;
  font-weight: 800;
  padding: 10rpx 32rpx;
  border-radius: 999rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid currentColor;
  letter-spacing: 2rpx;
}

@keyframes risk-glow {
  0%, 100% { box-shadow: 0 0 12rpx rgba(255,77,79,0.2); }
  50% { box-shadow: 0 0 24rpx rgba(255,77,79,0.5); }
}

.score-display {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.score-num {
  font-size: 140rpx;
  font-weight: 900;
  font-family: 'DIN Alternate', 'Helvetica Neue', sans-serif;
  line-height: 1;
  letter-spacing: -4rpx;
}
.score-total {
  font-size: 30rpx;
  color: #C0C0C0;
  font-weight: 500;
  margin-left: 8rpx;
}

.source-tag {
  font-size: 24rpx;
  color: #B0B0B0;
  font-weight: 500;
  margin-bottom: 36rpx;
  letter-spacing: 1rpx;
}

/* 结论 + 行动指引 */
.conclusion-block {
  width: 100%;
  background: rgba(0,0,0,0.02);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
}
.conclusion-line {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 12rpx;
}
.conclusion-icon { font-size: 30rpx; flex-shrink: 0; margin-top: 2rpx; }
.conclusion-text { font-size: 28rpx; font-weight: 700; line-height: 1.5; }
.advice-line { padding-left: 40rpx; }
.advice-text { font-size: 26rpx; color: #666; line-height: 1.6; }

/* ======== 通用内容卡片 ======== */
.content-card {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.9);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.03), inset 0 2rpx 6rpx rgba(255,255,255,0.7);
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.card-title { font-size: 34rpx; font-weight: 800; color: #111; }

/* ======== 风险折叠面板 ======== */
.risk-panel {
  background: rgba(255,255,255,0.6);
  border: 1rpx solid rgba(0,0,0,0.04);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  transition: all 0.2s ease;
}
.risk-panel:last-child { margin-bottom: 0; }
.risk-panel-open { border-color: rgba(46,107,255,0.1); background: rgba(255,255,255,0.85); }

.risk-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}
.risk-panel-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.risk-panel-icon { font-size: 32rpx; }
.risk-panel-title { font-size: 30rpx; font-weight: 700; color: #222; }

.risk-panel-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.risk-panel-tag {
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.rtag-high { color: #FF4D4F; background: #FFF1F0; }
.rtag-mid { color: #FAAD14; background: #FFFBE6; }
.rtag-low { color: #52C41A; background: #F6FFED; }
.rtag-grey { color: #9CA3AF; background: #F3F4F6; }

.risk-panel-arrow {
  font-size: 28rpx;
  color: #CCC;
  font-weight: 700;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
  display: inline-block;
}
.arrow-up { transform: rotate(-90deg); }

.risk-panel-body {
  padding: 0 28rpx 28rpx;
}
.risk-panel-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ======== 关键隐患 ======== */
.issue-item-wrap { margin-bottom: 20rpx; }
.issue-item-wrap:last-child { margin-bottom: 0; }

.issue-item {
  background: rgba(255,255,255,0.6);
  border: 1rpx solid rgba(0,0,0,0.04);
  border-radius: 20rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
}
.issue-locked { opacity: 0.7; }

.issue-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.issue-idx {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #FF4D4F, #FF7875);
  color: #FFF;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.issue-idx-locked { background: #D9D9D9; }

.issue-tag {
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.itag-high { color: #FF4D4F; background: #FFF1F0; }
.itag-mid { color: #FAAD14; background: #FFFBE6; }
.itag-low { color: #52C41A; background: #F6FFED; }
.itag-grey { color: #9CA3AF; background: #F3F4F6; }

.issue-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
  line-height: 1.4;
}
.issue-name-blur {
  filter: blur(4px);
  -webkit-filter: blur(4px);
  user-select: none;
}

.issue-detail { padding-left: 4rpx; }
.issue-consequence {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  font-weight: 500;
  margin-bottom: 6rpx;
  line-height: 1.6;
}
.issue-suggestion {
  display: block;
  font-size: 24rpx;
  color: #52C41A;
  font-weight: 500;
  line-height: 1.6;
}

.issue-lock-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(255,255,255,0.95), rgba(255,255,255,0));
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 20rpx;
}
.lock-mask-text {
  font-size: 24rpx;
  color: #2E6BFF;
  font-weight: 600;
}

.unlock-share-row {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}
.unlock-share-btn {
  background: linear-gradient(135deg, #2E6BFF, #1A4BFF);
  color: #FFF;
  font-size: 26rpx;
  font-weight: 700;
  padding: 20rpx 48rpx;
  border-radius: 999rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(46,107,255,0.25);
  margin: 0; line-height: inherit;
}
.unlock-share-btn::after { display: none; }
.unlock-share-btn-active { opacity: 0.8; transform: scale(0.96); }

/* ======== PRO 升级卡 ======== */
.pro-card {
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20px);
  border: 2rpx solid rgba(139,92,246,0.2);
  border-radius: 32rpx;
  padding: 36rpx 40rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 12rpx 40rpx rgba(139,92,246,0.06);
}
.pro-card-active { transform: scale(0.98); opacity: 0.9; }
.pro-title { font-size: 30rpx; font-weight: 800; color: #111; }
.pro-crown { font-size: 32rpx; }
.pro-desc { font-size: 24rpx; color: #888; font-weight: 400; margin-top: 8rpx; }
.pro-btn {
  background: linear-gradient(135deg, #8B5CF6, #6D28D9);
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(139,92,246,0.3);
  flex-shrink: 0;
}

/* ======== 底部固定操作栏 ======== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(0,0,0,0.04);
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 24rpx rgba(0,0,0,0.04);
}
.bottom-bar-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 8rpx 0;
  position: relative;
  background: none;
  border: none;
  margin: 0;
  line-height: inherit;
  font-size: inherit;
  color: inherit;
}
.bottom-bar-btn::after { display: none; }
.bottom-bar-share-btn { color: inherit; }
.bottom-bar-icon { font-size: 36rpx; }
.bottom-bar-label { font-size: 22rpx; color: #666; font-weight: 500; }
.bottom-bar-btn-active { opacity: 0.6; }

.bottom-bar-pro-btn .bottom-bar-icon { font-size: 36rpx; }
.bottom-bar-pro-btn .bottom-bar-label {
  color: #8B5CF6;
  font-weight: 700;
}

/* ======== 风险标签统一色系 ======== */
.tag-high { color: #FF4D4F; background: #FFF1F0; }
.tag-mid { color: #FAAD14; background: #FFFBE6; }
.tag-low { color: #52C41A; background: #F6FFED; }
.tag-grey { color: #9CA3AF; background: #F3F4F6; }

/* =========================================================
   🚨 以下为纯净追加的新动效样式：AI 参谋魔法卡片
   (完全隔离，绝不破坏上面任何一层原版布局)
========================================================= */

/* AI 专属卡片动效 */
.ai-card {
  position: relative;
  background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(245,248,255,0.9) 100%);
  border: 2rpx solid rgba(46, 107, 255, 0.3);
  box-shadow: 0 16rpx 48rpx rgba(46, 107, 255, 0.15), inset 0 2rpx 10rpx rgba(255,255,255,0.8);
  overflow: hidden;
}

/* 顶部标题区 */
.ai-header { display: flex; align-items: center; margin-bottom: 30rpx; padding-bottom: 20rpx; border-bottom: 1rpx dashed rgba(46, 107, 255, 0.2); }
@keyframes float-star { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-4rpx) scale(1.1); } }
.ai-icon { font-size: 36rpx; margin-right: 12rpx; animation: float-star 2s infinite; }
.ai-title { font-size: 32rpx; font-weight: 900; color: #111; letter-spacing: 1rpx; flex: 1; }
.ai-tag { font-size: 20rpx; background: rgba(46, 107, 255, 0.1); color: #2E6BFF; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: 800; border: 1rpx solid rgba(46, 107, 255, 0.2); }

/* 科幻扫描加载区 */
.ai-loading { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0 20rpx; }
.scanning-box { width: 100%; height: 6rpx; background: rgba(0,0,0,0.05); border-radius: 999rpx; overflow: hidden; margin-bottom: 30rpx; position: relative; }
@keyframes scan-laser { 0% { left: -50%; } 100% { left: 100%; } }
.scanning-light { position: absolute; top: 0; left: -50%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, #2E6BFF, transparent); animation: scan-laser 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
@keyframes pulse-text { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
.ai-loading-text { font-size: 26rpx; color: #2E6BFF; font-weight: 800; animation: pulse-text 2s infinite; }

/* 诊断文字内容 */
.ai-content { min-height: 120rpx; }
.ai-text { font-size: 28rpx; color: #333; line-height: 1.8; font-weight: 600; white-space: pre-wrap; letter-spacing: 1rpx; }
@keyframes blink-cursor { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
.ai-cursor { font-weight: 900; color: #2E6BFF; margin-left: 4rpx; animation: blink-cursor 0.8s infinite; }