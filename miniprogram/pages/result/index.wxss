.custom-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; }
.glass-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(40px); pointer-events: none; }
.result-page { position: relative; z-index: 2; min-height: 100vh; display: flex; flex-direction: column; }

.custom-nav { position: fixed; top: 0; left: 0; width: 100%; z-index: 99; background: rgba(255, 255, 255, 0.6); backdrop-filter: blur(20px); border-bottom: 1rpx solid rgba(0, 0, 0, 0.05); }
.nav-content { height: 100%; display: flex; align-items: center; justify-content: center; position: relative; padding: 0 32rpx; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #111; }
.nav-btn-left, .nav-btn-right { position: absolute; font-size: 26rpx; color: #4B5563; font-weight: 600; padding: 12rpx 24rpx; background: rgba(255,255,255,0.6); border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,0.9); }
.nav-btn-left { left: 32rpx; }
.nav-btn-right { right: 32rpx; }

.main-content { padding: 0 32rpx 80rpx; }

/* 玻璃态基础卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.05), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
}

/* 卡片1：总览 */
.overview-card { display: flex; flex-direction: column; align-items: center; padding-top: 50rpx; }
.level-badge { font-size: 28rpx; font-weight: 800; padding: 10rpx 32rpx; border-radius: 999rpx; margin-bottom: 24rpx; }
.score-display { margin-bottom: 24rpx; display: flex; align-items: baseline; }
.score-num { font-size: 100rpx; font-weight: 900; font-family: 'DIN Alternate', sans-serif; line-height: 1; text-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1); }
.score-total { font-size: 28rpx; color: #666; font-weight: 600; margin-left: 12rpx; }
.tags-row { display: flex; gap: 16rpx; margin-bottom: 50rpx; }
.tag-item { font-size: 24rpx; color: #4B5563; background: rgba(0,0,0,0.04); padding: 8rpx 20rpx; border-radius: 8rpx; font-weight: 600; }
.action-row { display: flex; gap: 20rpx; width: 100%; }
.btn-primary-glass, .btn-secondary-glass { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 20rpx; font-size: 28rpx; font-weight: 700; border: 2rpx solid transparent; }
.btn-secondary-glass { background: rgba(255,255,255,0.8); color: #333; border-color: #E5E7EB; }

/* 通用标题 */
.card-title { font-size: 32rpx; font-weight: 800; color: #111; margin-bottom: 20rpx; }
.card-desc { font-size: 28rpx; color: #4B5563; line-height: 1.6; font-weight: 500; }

/* 隐患列表 */
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.header-link { font-size: 24rpx; color: #2E6BFF; font-weight: 600; }
.issue-item { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.04); }
.issue-item:last-child { border-bottom: none; padding-bottom: 0; }
.issue-dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-right: 16rpx; }
.issue-text { flex: 1; font-size: 28rpx; color: #333; font-weight: 600; }
.issue-tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: bold; }

/* 升级卡片 */
.promo-card { display: flex; align-items: center; justify-content: space-between; background: linear-gradient(135deg, rgba(245,243,255,0.8) 0%, rgba(237,233,254,0.9) 100%); border-color: rgba(139,92,246,0.2); }
.promo-title { font-size: 30rpx; font-weight: 800; color: #111; margin-bottom: 8rpx; }
.promo-desc { font-size: 24rpx; color: #6B7280; }
.promo-btn { background: #8B5CF6; color: #FFF; font-size: 24rpx; font-weight: 700; padding: 16rpx 32rpx; border-radius: 999rpx; box-shadow: 0 8rpx 20rpx rgba(139,92,246,0.3); }