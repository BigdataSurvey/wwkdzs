/* ======== 全局基础样式 ======== */
page {
  background: #0A0A0F;
  background-image:
    radial-gradient(circle at 85% 10%, rgba(46, 107, 255, 0.12), transparent 40%),
    radial-gradient(circle at 15% 85%, rgba(120, 80, 220, 0.06), transparent 35%);
  color: #F0F2F5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view,
image {
  box-sizing: border-box;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 176rpx;
}

.section {
  margin-bottom: 24rpx;
}

/* ======== 卡片 ======== */
.card {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(18rpx);
}

.panel {
  padding: 28rpx;
}

/* ======== Hero 卡片 ======== */
.hero-card {
  padding: 34rpx 30rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, rgba(46, 107, 255, 0.94) 0%, rgba(42, 91, 205, 0.88) 48%, rgba(35, 57, 117, 0.92) 100%);
  box-shadow: 0 24rpx 60rpx rgba(8, 28, 67, 0.35);
}

.hero-title {
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: #FFFFFF;
}

.hero-subtitle {
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.hero-pill {
  margin-right: 14rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.96);
  font-size: 23rpx;
}

/* ======== 排版 ======== */
.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.section-desc {
  font-size: 24rpx;
  color: rgba(200, 210, 225, 0.6);
}

.caption {
  font-size: 22rpx;
  color: rgba(200, 210, 225, 0.55);
}

.body-text {
  font-size: 27rpx;
  line-height: 1.7;
  color: #D0D8E8;
}

/* ======== 网格 ======== */
.grid-2 {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.grid-2 > view {
  width: 48.2%;
  margin-bottom: 18rpx;
}

/* ======== 按钮 ======== */
.primary-btn,
.secondary-btn,
.ghost-btn,
.disabled-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 92rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-btn {
  color: #FFFFFF;
  background: linear-gradient(135deg, #2E6BFF 0%, #5790FF 100%);
  box-shadow: 0 14rpx 40rpx rgba(46, 107, 255, 0.32);
}

.secondary-btn {
  color: #DDEAFF;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.ghost-btn {
  color: #C8D4E8;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.disabled-btn {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(200, 210, 225, 0.35);
}

/* ======== 标签 ======== */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.badge-blue {
  background: rgba(46, 107, 255, 0.14);
  color: #93B4FF;
  border: 1rpx solid rgba(92, 144, 255, 0.25);
}

.badge-orange {
  background: rgba(243, 122, 64, 0.12);
  color: #FFD2B7;
  border: 1rpx solid rgba(243, 122, 64, 0.22);
}

.badge-green {
  background: rgba(26, 180, 112, 0.12);
  color: #BDF4D8;
  border: 1rpx solid rgba(26, 180, 112, 0.22);
}

.badge-gray {
  background: rgba(255, 255, 255, 0.05);
  color: #B0BAC8;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* ======== 空状态 ======== */
.empty-card {
  text-align: center;
  padding: 44rpx 28rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 14rpx;
}

.empty-desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(200, 210, 225, 0.55);
}

/* ======== Logo ======== */
.logo-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
}

.logo-md {
  width: 116rpx;
  height: 116rpx;
  border-radius: 36rpx;
}

/* ======== 交互 ======== */
.tap-scale {
  transform: scale(0.985);
  opacity: 0.96;
}

.link-text {
  font-size: 26rpx;
  color: #7EB0FF;
}

/* ======== 列表 ======== */
.list-line {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.list-line:last-child {
  border-bottom: none;
}

.icon-chip {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(46, 107, 255, 0.12);
  color: #B0C8FF;
  font-size: 28rpx;
  font-weight: 700;
}

.inline-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.muted {
  color: rgba(200, 210, 225, 0.55);
}
